OPENAI_API_KEY=sk-...
# Optional: custom API base (Azure, proxy, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Comma-separated model ids for the sidebar dropdown (defaults if unset)
# INTERVIEW_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo,o1-mini

# Optional default selection (must appear in INTERVIEW_MODELS or built-in list)
# INTERVIEW_DEFAULT_MODEL=gpt-4o
